# Copy this file to `.env` and fill in your key. `.env` is gitignored.

# Anthropic Claude API key (first-party) — used by the render server for the
# AI "brand-from-a-prompt" and script-writer features.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the Claude model (defaults to claude-opus-4-8).
# CLAUDE_MODEL=claude-opus-4-8

# Optional: ComfyUI endpoint for the experimental AI watercolor pass.
# COMFY_URL=http://127.0.0.1:8188

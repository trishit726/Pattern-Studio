{
  "_comment": "ComfyUI img2img workflow (API format) for painterly backgrounds. Stock SD1.5 graph. Export your own working graph from ComfyUI (gear icon > 'Save (API Format)') and paste it here if your OpenVINO build uses different node names. render-server.mjs injects values into the node IDs listed in COMFY_NODES at the top of that file — keep those IDs in sync with this file.",
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 20,
      "cfg": 7,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 0.6,
      "model": ["4", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["12", 0]
    }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "v1-5-pruned-emaonly-fp16.safetensors" }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "watercolor painting", "clip": ["4", 1] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "ugly, blurry, low quality, text, watermark, oversaturated", "clip": ["4", 1] }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": { "image": "input.png", "upload": "image" }
  },
  "12": {
    "class_type": "VAEEncode",
    "inputs": { "pixels": ["10", 0], "vae": ["4", 2] }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["3", 0], "vae": ["4", 2] }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "remotion_bg", "images": ["8", 0] }
  }
}
